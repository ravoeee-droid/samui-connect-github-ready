{
  "name": "Event",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Event title"
    },
    "category": {
      "type": "string",
      "enum": [
        "activities",
        "nightlife",
        "coworking",
        "social"
      ],
      "description": "Event category"
    },
    "samui_area": {
      "type": "string",
      "enum": [
        "Chaweng",
        "Lamai",
        "Bophut",
        "Maenam"
      ]
    },
    "time_label": {
      "type": "string",
      "enum": [
        "now",
        "today",
        "tonight",
        "tomorrow"
      ],
      "description": "When the event happens"
    },
    "starts_at": {
      "type": "string",
      "description": "Start time description"
    },
    "max_people": {
      "type": "number"
    },
    "is_paid": {
      "type": "boolean",
      "default": false
    },
    "creator_name": {
      "type": "string"
    },
    "creator_avatar": {
      "type": "string"
    },
    "attendees_count": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "title",
    "category"
  ]
}